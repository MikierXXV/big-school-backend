# ============================================
# CONFIGURACIÓN DE ENTORNO - BIG SCHOOL BACKEND
# ============================================
# Copia este archivo como .env y configura los valores
# NUNCA subas el archivo .env al repositorio

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ============================================
# BASE DE DATOS
# ============================================
# Configuración para PostgreSQL (u otro adaptador)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=big_school
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL=false

# ============================================
# JWT - CONFIGURACIÓN DE TOKENS
# ============================================
# IMPORTANTE: Genera claves seguras para producción
# Puedes usar: openssl rand -base64 64

# Clave secreta para Access Token
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars

# Clave secreta para Refresh Token (diferente del access)
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars

# Tiempo de expiración Access Token (en segundos)
# 5 horas = 18000 segundos
JWT_ACCESS_EXPIRATION=18000

# Tiempo de expiración Refresh Token (en segundos)
# 3 días = 259200 segundos
JWT_REFRESH_EXPIRATION=259200

# Issuer del token (identificador de la aplicación)
JWT_ISSUER=big-school-api

# Audience del token
JWT_AUDIENCE=big-school-client

# ============================================
# HASHING - CONFIGURACIÓN DE CONTRASEÑAS
# ============================================
# Rounds para bcrypt (mayor = más seguro pero más lento)
HASH_SALT_ROUNDS=12

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ============================================
# SUPER ADMIN INICIAL (Feature 012)
# ============================================
# Credenciales del Super Administrador creado automáticamente al arrancar
# Este usuario tiene system_role = 'super_admin' y permisos completos
# IMPORTANTE: Cambiar estas credenciales en producción
SUPER_ADMIN_EMAIL=<email>
SUPER_ADMIN_PASSWORD=<pwd>
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# ============================================
# OAUTH - AUTENTICACIÓN SOCIAL (Feature 013)
# ============================================
# Genera con: openssl rand -base64 48
OAUTH_STATE_SECRET=

# Duración del state en segundos (default: 300 = 5 minutos)
OAUTH_STATE_EXPIRES_IN=300

# Google OAuth
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth
# Obtener en: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# 'common' para cuentas personales y de organización mezcladas
MICROSOFT_TENANT_ID=common

# ============================================
# EMAIL - ENVÍO TRANSACCIONAL (Feature 019)
# ============================================
# Servicio: Resend (https://resend.com)
# Obtener API key en: https://resend.com/api-keys
#
# COMPORTAMIENTO POR ENTORNO:
#   NODE_ENV=production + RESEND_API_KEY → Emails reales. El token de verificación
#     NO se expone en la respuesta HTTP (flujo seguro de producción).
#   NODE_ENV=development (o sin RESEND_API_KEY) → No se envían emails.
#     El token se incluye en la respuesta JSON para facilitar pruebas locales.
#
# En free trial, los emails se envían desde onboarding@resend.dev.
# Para emails branded necesitas verificar tu dominio en el dashboard de Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Dirección remitente (debe pertenecer a un dominio verificado en Resend)
# En free trial usa: onboarding@resend.dev
EMAIL_FROM=noreply@yourdomain.com

# URL base del frontend para construir los links en los emails
# Ejemplo producción: https://app.healthcaresuite.com
APP_BASE_URL=http://localhost:5173

# Nombre de la aplicación que aparece en los emails transaccionales
APP_NAME=Health Care Suite
